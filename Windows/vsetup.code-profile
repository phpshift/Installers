  "snippets": "{\"snippets\":{\"global.code-snippets\":\"{\\n\\t\\\"PP - Python print\\\": {\\n\\t\\t\\\"scope\\\": \\\"python\\\",\\n\\t\\t\\\"prefix\\\": \\\"pp\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"print(${CLIPBOARD})\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Print copied item or selected expression (Python)\\\"\\n\\t},\\n\\t\\\"PP - PHP print\\\": {\\n\\t\\t\\\"scope\\\": \\\"php\\\",\\n\\t\\t\\\"prefix\\\": \\\"pp\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"echo '<pre>';\\\",\\n\\t\\t\\t\\\"print_r(${CLIPBOARD});\\\",\\n\\t\\t\\t\\\"echo '</pre>';\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Print copied item or selected expression (PHP)\\\"\\n\\t},\\n\\t\\\"PP - JavaScript print\\\": {\\n\\t\\t\\\"scope\\\": \\\"javascript\\\",\\n\\t\\t\\\"prefix\\\": \\\"pp\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"console.log(${CLIPBOARD});\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Print copied item or selected expression (JavaScript)\\\"\\n\\t},\\n\\t\\\"PD - Python debug print\\\": {\\n\\t\\t\\\"scope\\\": \\\"python\\\",\\n\\t\\t\\\"prefix\\\": \\\"pd\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"print(${CLIPBOARD})\\\",\\n\\t\\t\\t\\\"sys.exit()\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Pretty debug print (Python)\\\"\\n\\t},\\n\\t\\\"PD - PHP debug print\\\": {\\n\\t\\t\\\"scope\\\": \\\"php\\\",\\n\\t\\t\\\"prefix\\\": \\\"pd\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"echo '<pre>';\\\",\\n\\t\\t\\t\\\"print_r(${CLIPBOARD});\\\",\\n\\t\\t\\t\\\"die;\\\",\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Debug dump output (PHP)\\\"\\n\\t},\\n\\t\\\"PD - JavaScript debug print\\\": {\\n\\t\\t\\\"scope\\\": \\\"javascript\\\",\\n\\t\\t\\\"prefix\\\": \\\"pd\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"console.log(${CLIPBOARD});\\\",\\n\\t\\t\\t\\\"return false;\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Deep debug output (JavaScript)\\\"\\n\\t},\\n\\t\\\"Return False (ff) - Python\\